1. How to get 2nd largest salary form employee table?

//Using Distinct and order by and offset
Select distinct salary
from employee
order by salary desc
Limit 1 offset 1

//Using Dense rank()- it handles duplicates
Select salary
from(
select salary,
dense_rank() over
(order by salary desc)as rnk
from employee) t
where rnk=2;

2. Write a query to get all Dept which don't have any employee?
    Emp (epmid, epmname, dept_id)
    Dept (deptid, deptname);

//Left Join
select d.deptid,d.deptname
from dept d
left join emp e
on d.deptid=e.deptid
where e.deptid is null;

