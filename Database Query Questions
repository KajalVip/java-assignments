4. Write a query to get the total salary, maximum, minimum, average salary of employees (job ID wise).

select jobid,
sum(salary),min(salary),max(salary),avg(salary)
from employee
group by jobid

5. Show only jobs whose average salary is greater than 10000

select jobid,
sum(salary),min(salary),max(salary),avg(salary)
from employee
group by jobid
having avg(salary)>10000;

